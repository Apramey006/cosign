# Gemini — free tier at https://aistudio.google.com/app/apikey (no credit card)
GEMINI_API_KEY=

# Signing secret for /v/[encoded] share URLs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Without this set, share links still work locally but won't verify in prod.
COSIGN_SHARE_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
